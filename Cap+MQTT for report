def do_trip(reason, reverse_hold=False):
    global trip, trip_reason, command
    global action_in_progress, mode, I_target
    if reverse_hold:
        enter_safe_hold(reason)
        return
    if not trip:
        print("TRIP:", reason)
    trip = True
    trip_reason = reason
    command = ""
    action_in_progress = False
    I_target = 0.0
    mode = "TRIPPED"
    pwm_off()

