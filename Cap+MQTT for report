def parse_energy_amount(text):
    text = text.strip()
    if not text:
        return E_STEP
    if text[0] in "=:":
        text = text[1:].strip()
    if text.endswith("J"):
        text = text[:-1].strip()
    try:
        value = float(text)
    except:
        return None
    if value <= 0.0:
        return None
    return value


